#!/usr/bin/env bash
# kernel-autotune-v2.sh
# Intelligent kernel tuning with predictable behavior and safety
# Improvements:
# - Deterministic configuration (no runtime surprises)
# - Better kernel detection with fallback chains
# - SSD detection and optimization
# - Intelligent NUMA handling
# - Better zram/zswap coordination
# - Thermal-aware tuning
# - Predictable state validation

set -euo pipefail
IFS=$'\n\t'

SCRIPT_NAME="$(basename "$0")"
WORKDIR="/etc/kernel-autotune"
CONFIG_FILE="$WORKDIR/config.sh"
STATE_FILE="$WORKDIR/state.json"
SYSCTL_CONF="/etc/sysctl.d/99-kernel-autotune.conf"
ZRAM_SCRIPT="/usr/local/bin/kernel-autotune-zram.sh"
LOG_FILE="/var/log/kernel-autotune.log"

VERBOSE=0

# ==================== Logging ====================
log() {
    local msg="[$SCRIPT_NAME] $*"
    echo "$msg"
    echo "$(date '+%Y-%m-%d %H:%M:%S'): $msg" >> "$LOG_FILE"
}

warn() { log "WARNING: $*"; }
error() { log "ERROR: $*"; exit 1; }
need_root() { [ "$EUID" -eq 0 ] || error "Must run as root"; }

# ==================== System Detection ====================
detect_kernel() {
    local k="$(uname -r | tr '[:upper:]' '[:lower:]')"
    
    # Ordered by specificity
    if   [[ "$k" == *xanmod* ]];   then echo "xanmod"
    elif [[ "$k" == *liquorix* ]]; then echo "liquorix"
    elif [[ "$k" == *zen* ]];      then echo "zen"
    elif [[ "$k" == *tkg* ]];      then echo "tkg"
    elif [[ "$k" == *ck* ]];       then echo "ck"
    elif [[ "$k" == *clear* ]];    then echo "clear"
    elif [[ "$k" == *cachyos* ]];  then echo "cachyos"
    else echo "generic"
    fi
}

is_laptop() {
    [ -d /sys/class/power_supply ] && \
    ls /sys/class/power_supply/*/type 2>/dev/null | grep -qi battery
}

is_handheld() {
    local node="$(hostname | tr '[:upper:]' '[:lower:]')"
    [[ "$node" == *"deck"* ]] || \
    [[ "$node" == *"ally"* ]] || \
    [ -e /sys/class/power_supply/axp20x-battery ]
}

get_ram_mb() {
    awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo
}

get_cpu_cores() {
    nproc 2>/dev/null || grep -c '^processor' /proc/cpuinfo || echo 1
}

is_numa_system() {
    [ -d /sys/devices/system/node/node1 ] && \
    [ "$(cat /sys/devices/system/node/node1/cpulist 2>/dev/null | wc -w)" -gt 0 ]
}

# Detect SSD/NVMe devices
has_ssd() {
    local found=0
    for disk in /sys/block/sd* /sys/block/nvme*; do
        [ -e "$disk/queue/rotational" ] || continue
        if [ "$(cat "$disk/queue/rotational" 2>/dev/null || echo 1)" -eq 0 ]; then
            found=1
            break
        fi
    done
    echo $found
}

# Check if thermal management is active
has_thermal_control() {
    [ -d /sys/class/thermal/thermal_zone0 ] && \
    [ -e /sys/class/thermal/thermal_zone0/temp ]
}

# ==================== Configuration Generation ====================
generate_config() {
    mkdir -p "$WORKDIR"
    
    local KERNEL=$(detect_kernel)
    local DEVICE_TYPE="desktop"
    local RAM_MB=$(get_ram_mb)
    local CPU_CORES=$(get_cpu_cores)
    local HAS_SSD=$(has_ssd)
    local IS_NUMA=$(is_numa_system && echo 1 || echo 0)
    local HAS_THERMAL=$(has_thermal_control && echo 1 || echo 0)
    
    # Determine device type
    if is_handheld; then
        DEVICE_TYPE="handheld"
    elif is_laptop; then
        DEVICE_TYPE="laptop"
    fi
    
    log "Detected: $KERNEL kernel, $DEVICE_TYPE, ${RAM_MB}MB RAM, $CPU_CORES cores, SSD=$HAS_SSD, NUMA=$IS_NUMA"
    
    # ==================== Base Defaults ====================
    SWAPPINESS=15
    DIRTY_RATIO=15
    DIRTY_BG_RATIO=5
    VFS_CACHE_PRESSURE=60
    CPU_GOVERNOR="schedutil"
    THP="madvise"
    ZRAM_ENABLED=1
    ZRAM_RATIO=50
    ZRAM_ALGO="zstd"
    ZSWAP_ENABLED=0
    NUMA_BALANCING=1
    COMPACT_UNEVICTABLE=1
    IO_SCHEDULER_SSD="mq-deadline"
    IO_SCHEDULER_HDD="bfq"
    
    # Network defaults
    TCP_CONGESTION="bbr"
    NET_QDISC="fq"
    
    # ==================== Kernel-Specific Tuning ====================
    case "$KERNEL" in
        xanmod)
            SWAPPINESS=10
            DIRTY_RATIO=20
            CPU_GOVERNOR="performance"
            THP="madvise"
            ZRAM_ALGO="zstd"
            TCP_CONGESTION="bbr"
            ;;
        liquorix|zen|cachyos)
            SWAPPINESS=20
            DIRTY_RATIO=15
            CPU_GOVERNOR="schedutil"
            ZRAM_RATIO=60
            ;;
        tkg)
            SWAPPINESS=12
            CPU_GOVERNOR="performance"
            ZRAM_RATIO=55
            ;;
        ck|clear)
            SWAPPINESS=8
            CPU_GOVERNOR="performance"
            DIRTY_RATIO=10
            ;;
        generic)
            SWAPPINESS=15
            CPU_GOVERNOR="schedutil"
            THP="defer+madvise"
            ;;
    esac
    
    # ==================== Device Type Adjustments ====================
    case "$DEVICE_TYPE" in
        handheld)
            CPU_GOVERNOR="schedutil"
            SWAPPINESS=25
            ZRAM_RATIO=100
            ZRAM_ALGO="lz4"  # Faster for lower power
            THP="never"      # Save battery
            DIRTY_RATIO=10
            ;;
        laptop)
            CPU_GOVERNOR="schedutil"
            SWAPPINESS=$((SWAPPINESS + 5))
            ZRAM_ALGO="lz4"
            if [ "$HAS_THERMAL" -eq 1 ]; then
                THP="defer+madvise"  # Reduce heat
            fi
            ;;
        desktop)
            # Keep optimized settings from kernel defaults
            ;;
    esac
    
    # ==================== RAM-Based Adjustments ====================
    if [ "$RAM_MB" -le 2048 ]; then
        ZRAM_ENABLED=1
        ZRAM_RATIO=150
        ZSWAP_ENABLED=0
        SWAPPINESS=30
        VFS_CACHE_PRESSURE=80
    elif [ "$RAM_MB" -le 4096 ]; then
        ZRAM_ENABLED=1
        ZRAM_RATIO=100
        ZSWAP_ENABLED=0
        SWAPPINESS=25
    elif [ "$RAM_MB" -le 8192 ]; then
        ZRAM_ENABLED=1
        ZRAM_RATIO=75
        ZSWAP_ENABLED=1  # Hybrid approach
    elif [ "$RAM_MB" -le 16384 ]; then
        ZRAM_RATIO=50
    else
        ZRAM_RATIO=30
        SWAPPINESS=5
    fi
    
    # ==================== NUMA Adjustments ====================
    if [ "$IS_NUMA" -eq 1 ]; then
        NUMA_BALANCING=1
        # On NUMA systems, prefer local memory
        VFS_CACHE_PRESSURE=50
    else
        NUMA_BALANCING=0
    fi
    
    # ==================== SSD Optimizations ====================
    if [ "$HAS_SSD" -eq 1 ]; then
        # More aggressive for SSDs (can handle writes)
        DIRTY_RATIO=20
        DIRTY_BG_RATIO=10
        IO_SCHEDULER_SSD="none"  # Most SSDs work best with none/noop
    fi
    
    # ==================== Write Configuration ====================
    cat > "$CONFIG_FILE" <<EOF
# Auto-generated kernel configuration
# Generated: $(date)
# Kernel: $KERNEL | Device: $DEVICE_TYPE | RAM: ${RAM_MB}MB | Cores: $CPU_CORES

# Memory
SWAPPINESS=$SWAPPINESS
DIRTY_RATIO=$DIRTY_RATIO
DIRTY_BG_RATIO=$DIRTY_BG_RATIO
VFS_CACHE_PRESSURE=$VFS_CACHE_PRESSURE

# CPU
CPU_GOVERNOR="$CPU_GOVERNOR"
THP="$THP"

# Swap/Compression
ZRAM_ENABLED=$ZRAM_ENABLED
ZRAM_RATIO=$ZRAM_RATIO
ZRAM_ALGO="$ZRAM_ALGO"
ZSWAP_ENABLED=$ZSWAP_ENABLED

# System
NUMA_BALANCING=$NUMA_BALANCING
COMPACT_UNEVICTABLE=$COMPACT_UNEVICTABLE

# IO
IO_SCHEDULER_SSD="$IO_SCHEDULER_SSD"
IO_SCHEDULER_HDD="$IO_SCHEDULER_HDD"

# Network
TCP_CONGESTION="$TCP_CONGESTION"
NET_QDISC="$NET_QDISC"

# Detection results
KERNEL="$KERNEL"
DEVICE_TYPE="$DEVICE_TYPE"
RAM_MB=$RAM_MB
CPU_CORES=$CPU_CORES
HAS_SSD=$HAS_SSD
IS_NUMA=$IS_NUMA
EOF
    
    # Write state for tracking changes
    cat > "$STATE_FILE" <<EOF
{
  "last_updated": "$(date -Iseconds)",
  "kernel": "$KERNEL",
  "device_type": "$DEVICE_TYPE",
  "ram_mb": $RAM_MB,
  "cpu_cores": $CPU_CORES,
  "has_ssd": $HAS_SSD,
  "is_numa": $IS_NUMA,
  "config": {
    "swappiness": $SWAPPINESS,
    "cpu_governor": "$CPU_GOVERNOR",
    "zram_ratio": $ZRAM_RATIO
  }
}
EOF
    
    log "Configuration generated and saved"
}

# ==================== Sysctl Tuning ====================
apply_sysctl() {
    source "$CONFIG_FILE"
    
    cat > "$SYSCTL_CONF" <<EOF
# Kernel Autotune v2 - $(date)
# Profile: $KERNEL kernel on $DEVICE_TYPE

# Kernel
kernel.sysrq = 176
kernel.numa_balancing = $NUMA_BALANCING
kernel.panic = 10
kernel.panic_on_oops = 0

# Memory Management
vm.swappiness = $SWAPPINESS
vm.vfs_cache_pressure = $VFS_CACHE_PRESSURE
vm.dirty_ratio = $DIRTY_RATIO
vm.dirty_background_ratio = $DIRTY_BG_RATIO
vm.dirty_expire_centisecs = 3000
vm.dirty_writeback_centisecs = 1500
vm.compact_unevictable_allowed = $COMPACT_UNEVICTABLE

# Memory overcommit (predictable behavior)
vm.overcommit_memory = 1
vm.overcommit_ratio = 50

# Network Performance
net.core.default_qdisc = $NET_QDISC
net.ipv4.tcp_congestion_control = $TCP_CONGESTION
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.core.somaxconn = 8192
net.core.netdev_max_backlog = 16384

# Network Optimizations
net.ipv4.tcp_slow_start_after_idle = 0
net.ipv4.tcp_mtu_probing = 1
net.ipv4.tcp_window_scaling = 1

# File System
fs.file-max = 2097152
fs.inotify.max_user_watches = 524288
fs.inotify.max_user_instances = 1024
EOF
    
    if ! sysctl --load="$SYSCTL_CONF" 2>&1 | tee -a "$LOG_FILE"; then
        warn "Some sysctl settings failed (may be OK if kernel doesn't support them)"
    else
        log "Sysctl settings applied successfully"
    fi
}

# ==================== ZRAM Setup ====================
setup_zram() {
    source "$CONFIG_FILE"
    
    [ "$ZRAM_ENABLED" -eq 0 ] && return 0
    
    local RAM_MB=$(get_ram_mb)
    local ZRAM_SIZE_MB=$((RAM_MB * ZRAM_RATIO / 100))
    local NUM_DEVICES=$(get_cpu_cores)
    
    # Limit to 8 devices max
    [ "$NUM_DEVICES" -gt 8 ] && NUM_DEVICES=8
    
    cat > "$ZRAM_SCRIPT" <<EOF
#!/usr/bin/env bash
set -euo pipefail

# Remove existing zram if any
for dev in /dev/zram*; do
    [ -b "\$dev" ] && swapoff "\$dev" 2>/dev/null || true
done
modprobe -r zram 2>/dev/null || true

# Setup new zram
modprobe zram num_devices=$NUM_DEVICES

for i in \$(seq 0 \$((NUM_DEVICES - 1))); do
    DEV="/dev/zram\$i"
    
    # Set algorithm (fallback to lz4 if zstd unavailable)
    if echo "$ZRAM_ALGO" > /sys/block/zram\$i/comp_algorithm 2>/dev/null; then
        :
    else
        echo "lz4" > /sys/block/zram\$i/comp_algorithm 2>/dev/null || true
    fi
    
    # Set size
    echo "$((ZRAM_SIZE_MB / NUM_DEVICES))M" > /sys/block/zram\$i/disksize
    
    # Create and enable swap
    mkswap "\$DEV" >/dev/null 2>&1
    swapon -p 100 "\$DEV" 2>/dev/null || echo "Warning: Failed to enable \$DEV"
done

echo "ZRAM: $NUM_DEVICES devices, ${ZRAM_SIZE_MB}MB total, algo=$ZRAM_ALGO"
EOF
    
    chmod +x "$ZRAM_SCRIPT"
    
    if "$ZRAM_SCRIPT" 2>&1 | tee -a "$LOG_FILE"; then
        log "ZRAM configured: $NUM_DEVICES devices, ${ZRAM_SIZE_MB}MB total"
    else
        warn "ZRAM setup encountered issues"
    fi
}

# ==================== ZSWAP Setup ====================
setup_zswap() {
    source "$CONFIG_FILE"
    
    [ "$ZSWAP_ENABLED" -eq 0 ] && return 0
    
    # Only enable if module exists
    if [ -d /sys/module/zswap ]; then
        echo "Y" > /sys/module/zswap/parameters/enabled 2>/dev/null || true
        echo "zstd" > /sys/module/zswap/parameters/compressor 2>/dev/null || \
            echo "lz4" > /sys/module/zswap/parameters/compressor 2>/dev/null || true
        echo "z3fold" > /sys/module/zswap/parameters/zpool 2>/dev/null || \
            echo "zbud" > /sys/module/zswap/parameters/zpool 2>/dev/null || true
        echo 20 > /sys/module/zswap/parameters/max_pool_percent 2>/dev/null || true
        log "ZSWAP enabled (hybrid with ZRAM)"
    fi
}

# ==================== IO Scheduler ====================
tune_io_scheduler() {
    source "$CONFIG_FILE"
    
    for device in /sys/block/*; do
        [ -e "$device/queue/scheduler" ] || continue
        
        local dev_name=$(basename "$device")
        
        # Skip virtual devices
        [[ "$dev_name" == loop* ]] && continue
        [[ "$dev_name" == zram* ]] && continue
        [[ "$dev_name" == sr* ]] && continue
        [[ "$dev_name" == dm-* ]] && continue
        
        local is_rotational=$(cat "$device/queue/rotational" 2>/dev/null || echo 0)
        local scheduler
        
        if [ "$is_rotational" -eq 1 ]; then
            scheduler="$IO_SCHEDULER_HDD"
        else
            scheduler="$IO_SCHEDULER_SSD"
        fi
        
        # Check if scheduler is available
        if grep -q "$scheduler" "$device/queue/scheduler" 2>/dev/null; then
            echo "$scheduler" > "$device/queue/scheduler" 2>/dev/null && \
                log "Set $dev_name scheduler to $scheduler" || true
        fi
    done
}

# ==================== CPU Governor ====================
tune_cpu_governor() {
    source "$CONFIG_FILE"
    
    local target="$CPU_GOVERNOR"
    
    # Always use schedutil on battery
    if is_laptop && ! grep -q "1" /sys/class/power_supply/AC*/online 2>/dev/null; then
        target="schedutil"
    fi
    
    for gov_file in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        [ -w "$gov_file" ] || continue
        
        # Check if governor is available
        local available=$(cat "$(dirname "$gov_file")/scaling_available_governors" 2>/dev/null || echo "")
        if [[ "$available" == *"$target"* ]]; then
            echo "$target" > "$gov_file" 2>/dev/null && \
                log "Set CPU governor to $target" || true
        fi
    done
}

# ==================== Transparent Huge Pages ====================
tune_thp() {
    source "$CONFIG_FILE"
    
    local thp_file="/sys/kernel/mm/transparent_hugepage/enabled"
    [ -f "$thp_file" ] || return 0
    
    echo "$THP" > "$thp_file" 2>/dev/null && \
        log "Set THP to $THP" || warn "Failed to set THP"
}

# ==================== FSTRIM ====================
enable_fstrim() {
    source "$CONFIG_FILE"
    
    [ "$HAS_SSD" -eq 0 ] && return 0
    
    if systemctl list-unit-files | grep -q fstrim.timer; then
        systemctl enable --now fstrim.timer 2>/dev/null && \
            log "Enabled fstrim.timer for SSD maintenance" || true
    fi
}

# ==================== Main Application ====================
apply_all() {
    generate_config
    apply_sysctl
    setup_zram
    setup_zswap
    tune_io_scheduler
    tune_cpu_governor
    tune_thp
    enable_fstrim
    
    log "All optimizations applied successfully"
    log "Profile: $(source "$CONFIG_FILE"; echo "$KERNEL on $DEVICE_TYPE with ${RAM_MB}MB RAM")"
}

# ==================== Installation ====================
install() {
    need_root
    log "Installing kernel autotune v2..."
    
    mkdir -p "$WORKDIR"
    cp "$0" /usr/local/bin/kernel-autotune
    chmod +x /usr/local/bin/kernel-autotune
    
    apply_all
    
    # Create systemd service
    cat > /etc/systemd/system/kernel-autotune.service <<'EOF'
[Unit]
Description=Kernel Autotune v2
After=local-fs.target
Before=systemd-user-sessions.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/kernel-autotune apply
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF
    
    systemctl daemon-reload
    systemctl enable kernel-autotune.service
    
    log "Installed successfully. Will run on every boot."
    log "Configuration: $CONFIG_FILE"
    log "State: $STATE_FILE"
}

# ==================== Uninstallation ====================
uninstall() {
    need_root
    log "Uninstalling kernel autotune..."
    
    systemctl disable --now kernel-autotune.service 2>/dev/null || true
    rm -f /etc/systemd/system/kernel-autotune.service
    rm -f /usr/local/bin/kernel-autotune
    rm -rf "$WORKDIR"
    rm -f "$SYSCTL_CONF"
    rm -f "$ZRAM_SCRIPT"
    
    systemctl daemon-reload
    
    log "Uninstalled successfully"
}

# ==================== Status ====================
show_status() {
    if [ ! -f "$STATE_FILE" ]; then
        echo "Not configured. Run 'install' first."
        exit 1
    fi
    
    echo "=== Kernel Autotune Status ==="
    cat "$STATE_FILE" 2>/dev/null || echo "State file not found"
    echo
    echo "=== Current ZRAM ==="
    swapon --show=NAME,TYPE,SIZE,USED,PRIO 2>/dev/null | grep zram || echo "No ZRAM active"
    echo
    echo "=== Logs (last 20 lines) ==="
    tail -n 20 "$LOG_FILE" 2>/dev/null || echo "No logs yet"
}

# ==================== Main ====================
case "${1:-apply}" in
    install)
        install
        ;;
    apply)
        need_root
        apply_all
        ;;
    uninstall)
        uninstall
        ;;
    status)
        show_status
        ;;
    *)
        echo "Usage: $0 {install|apply|uninstall|status}"
        echo
        echo "  install   - Install and enable on boot"
        echo "  apply     - Apply tuning now (run by systemd on boot)"
        echo "  uninstall - Remove everything"
        echo "  status    - Show current configuration and state"
        exit 1
        ;;
esac
